rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null || userId.matches("^mock_.*");
      allow create, update: if (request.auth != null && (
        request.auth.uid == userId || 
        resource.data.connectedUserId == request.auth.uid || 
        request.resource.data.connectedUserId == request.auth.uid
      )) || userId.matches("^mock_.*");
      allow delete: if (request.auth != null && request.auth.uid == userId) || userId.matches("^mock_.*");

      match /history/{logId} {
        allow read: if (request.auth != null && (
          request.auth.uid == userId || 
          get(/databases/$(database)/documents/users/$(userId)).data.connectedUserId == request.auth.uid
        )) || userId.matches("^mock_.*");
        allow create, update, delete: if (request.auth != null && request.auth.uid == userId) || userId.matches("^mock_.*");
      }
    }
  }
}
